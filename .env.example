# AgentMetrics - environment variables
# Copy to .env: cp .env.example .env

# Ports
API_PORT=8099
DASHBOARD_PORT=3099

# Database — SQLite by default, no setup needed
DATABASE_URL=sqlite:///./data/agentmetrics.db

# PostgreSQL (optional):
# DATABASE_URL=postgresql://agentmetrics:agentmetrics@postgres:5432/agentmetrics

# Environment
ENVIRONMENT=production

# Frontend URL — used for CORS allow-list
FRONTEND_URL=http://localhost:3099

# PostgreSQL profile only
POSTGRES_PASSWORD=agentmetrics
