# AgentMetrics API - environment variables
# Copy to .env: cp .env.example .env

# Database — SQLite by default, no setup needed
DATABASE_URL=sqlite:///./data/agentmetrics.db

# PostgreSQL (optional):
# DATABASE_URL=postgresql://agentmetrics:agentmetrics@localhost:5432/agentmetrics

# Environment
ENVIRONMENT=production

# URLs
FRONTEND_URL=http://localhost:3099
APP_URL=http://localhost:3099
API_URL=http://localhost:8099
