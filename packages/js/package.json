{
  "name": "agentmetrics",
  "version": "0.2.0",
  "description": "Monitor your AI agents. Track cost, latency, and errors in two lines of code.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "agentmetrics": "bin/agentmetrics.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint src",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "ai agent monitoring",
    "llm monitoring",
    "ai agent observability",
    "llm observability",
    "langchain monitoring",
    "crewai monitoring",
    "openai cost tracker",
    "llm cost tracking",
    "ai agent tracing",
    "open source llm monitoring",
    "langsmith alternative",
    "langfuse alternative"
  ],
  "author": "AgentMetrics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andalabx/agentmetrics.git"
  },
  "homepage": "https://github.com/andalabx/agentmetrics",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@agentmetrics/core": "workspace:*",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
