{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "newLine": "lf",
    "skipLibCheck": true
  },
  "include": ["index.ts", "../_shared/core.ts"]
}
