{
  "name": "agentmetrics-hermes",
  "version": "0.1.0",
  "type": "module",
  "description": "AgentMetrics observability plugin for Hermes agents",
  "license": "MIT",
  "homepage": "https://github.com/andalabx/agentmetrics",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andalabx/agentmetrics.git"
  },
  "keywords": [
    "hermes",
    "agentmetrics",
    "observability",
    "ai-agents",
    "monitoring"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "hermes": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "hermes.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "hermes": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "hermes": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22"
  }
}
