{
  "name": "agentmetrics-langchain",
  "version": "0.2.0",
  "type": "module",
  "description": "AgentMetrics observability integration for LangChain.js",
  "license": "MIT",
  "homepage": "https://github.com/andalabx/agentmetrics",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andalabx/agentmetrics.git"
  },
  "keywords": [
    "langchain",
    "agentmetrics",
    "observability",
    "ai-agents",
    "monitoring"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --no-splitting --external @langchain/core",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0"
  },
  "devDependencies": {
    "@agentmetrics/core": "workspace:*",
    "@langchain/core": ">=0.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
